# Frontend build env — copy this to project root as `.env.production`
# (next to package.json) BEFORE running `npm run build`.
# Vite reads this only during production builds; dev (.env.local) is unaffected.

VITE_API_BASE_URL=https://acr-mechanics.in/api/v1
# VITE_BASE_PATH=/app/   # optional — defaults to /app/ when mode=production
